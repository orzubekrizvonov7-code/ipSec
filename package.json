{
  "name": "ipsec-wizard-app",
  "private": true,
  "version": "1.0.0",
  "description": "Windows Server IPSec wizard app",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "build:ui": "vite build",
    "build": "npm run build:ui && electron-builder --win portable"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "electron": "^38.0.0",
    "electron-builder": "^26.0.12",
    "vite": "^8.0.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.orzubek.ipsecwizard",
    "productName": "IPSec Wizard",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}